<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.37.0">
  <bpmn:message id="Message_AntragEingegangen" name="Msg_AntragEingegangen" />
  <bpmn:error id="Error_ValidierungFehler" name="Validierungsfehler" errorCode="Err_ValidierungFehler" />
  <bpmn:process id="GenehmigungsProzess" name="Genehmigungsprozess" isExecutable="true" camunda:historyTimeToLive="30">
    <bpmn:startEvent id="StartEvent_AntragEingegangen" name="Antrag eingegangen">
      <bpmn:outgoing>SequenceFlow_Start_Validieren</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1" messageRef="Message_AntragEingegangen" />
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_AntragValidieren" name="Antrag validieren" camunda:type="external" camunda:topic="antragValidieren">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="extIn_antragsDaten">${extIn_antragsDaten}</camunda:inputParameter>
          <camunda:outputParameter name="int_validierungsErgebnis">${validierungsErgebnis}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SequenceFlow_Start_Validieren</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_Validieren_Pruefen</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="BoundaryEvent_FehlerAufgetreten" name="Fehler aufgetreten" attachedToRef="Task_AntragValidieren">
      <bpmn:outgoing>SequenceFlow_Fehler_Abgebrochen</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_1" errorRef="Error_ValidierungFehler" />
    </bpmn:boundaryEvent>
    <bpmn:userTask id="Task_AntragPruefen" name="Antrag prüfen" camunda:assignee="${int_sachbearbeiter}">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="int_antragStatus">${int_antragStatus}</camunda:inputParameter>
          <camunda:outputParameter name="int_genehmigungsEntscheidung">${genehmigungsEntscheidung}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SequenceFlow_Validieren_Pruefen</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_Pruefen_Gateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_AntragGenehmigt" name="Antrag genehmigt?" default="SequenceFlow_AntragGenehmigt_Nein">
      <bpmn:incoming>SequenceFlow_Pruefen_Gateway</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_AntragGenehmigt_Ja</bpmn:outgoing>
      <bpmn:outgoing>SequenceFlow_AntragGenehmigt_Nein</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="SequenceFlow_AntragGenehmigt_Ja" name="Ja" sourceRef="Gateway_AntragGenehmigt" targetRef="Task_BenachrichtigungSenden">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">
        ${int_genehmigungsEntscheidung == 'genehmigt'}
      </bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SequenceFlow_AntragGenehmigt_Nein" name="Nein" sourceRef="Gateway_AntragGenehmigt" targetRef="EndEvent_AntragAbgelehnt" />
    <bpmn:serviceTask id="Task_BenachrichtigungSenden" name="Benachrichtigung senden" camunda:type="external" camunda:topic="benachrichtigungSenden">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="extOut_ergebnisBericht">${ergebnisBericht}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SequenceFlow_AntragGenehmigt_Ja</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_Benachrichtigung_Ende</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_AntragGenehmigt" name="Antrag genehmigt">
      <bpmn:incoming>SequenceFlow_Benachrichtigung_Ende</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_AntragAbgelehnt" name="Antrag abgelehnt">
      <bpmn:incoming>SequenceFlow_AntragGenehmigt_Nein</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_ValidierungFehlgeschlagen" name="Validierung fehlgeschlagen">
      <bpmn:incoming>SequenceFlow_Fehler_Abgebrochen</bpmn:incoming>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_End" errorRef="Error_ValidierungFehler" />
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="SequenceFlow_Start_Validieren" sourceRef="StartEvent_AntragEingegangen" targetRef="Task_AntragValidieren" />
    <bpmn:sequenceFlow id="SequenceFlow_Validieren_Pruefen" sourceRef="Task_AntragValidieren" targetRef="Task_AntragPruefen" />
    <bpmn:sequenceFlow id="SequenceFlow_Pruefen_Gateway" sourceRef="Task_AntragPruefen" targetRef="Gateway_AntragGenehmigt" />
    <bpmn:sequenceFlow id="SequenceFlow_Benachrichtigung_Ende" sourceRef="Task_BenachrichtigungSenden" targetRef="EndEvent_AntragGenehmigt" />
    <bpmn:sequenceFlow id="SequenceFlow_Fehler_Abgebrochen" sourceRef="BoundaryEvent_FehlerAufgetreten" targetRef="EndEvent_ValidierungFehlgeschlagen" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="GenehmigungsProzess">
      <bpmndi:BPMNShape id="StartEvent_AntragEingegangen_di" bpmnElement="StartEvent_AntragEingegangen">
        <dc:Bounds x="152" y="122" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="139" y="165" width="64" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AntragValidieren_di" bpmnElement="Task_AntragValidieren">
        <dc:Bounds x="250" y="100" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AntragPruefen_di" bpmnElement="Task_AntragPruefen">
        <dc:Bounds x="430" y="100" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AntragGenehmigt_di" bpmnElement="Gateway_AntragGenehmigt" isMarkerVisible="true">
        <dc:Bounds x="615" y="115" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="611" y="77.5" width="58" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_BenachrichtigungSenden_di" bpmnElement="Task_BenachrichtigungSenden">
        <dc:Bounds x="730" y="100" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_AntragGenehmigt_di" bpmnElement="EndEvent_AntragGenehmigt">
        <dc:Bounds x="942" y="122" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="917" y="165" width="87" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_ValidierungFehlgeschlagen_di" bpmnElement="EndEvent_ValidierungFehlgeschlagen">
        <dc:Bounds x="292" y="302" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="273" y="345" width="75" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_AntragAbgelehnt_di" bpmnElement="EndEvent_AntragAbgelehnt">
        <dc:Bounds x="622" y="262" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="599" y="305" width="84" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BoundaryEvent_FehlerAufgetreten_di" bpmnElement="BoundaryEvent_FehlerAufgetreten">
        <dc:Bounds x="292" y="162" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="266" y="205" width="90" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="SequenceFlow_Start_Validieren_di" bpmnElement="SequenceFlow_Start_Validieren">
        <di:waypoint x="188" y="140" />
        <di:waypoint x="250" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SequenceFlow_Validieren_Pruefen_di" bpmnElement="SequenceFlow_Validieren_Pruefen">
        <di:waypoint x="370" y="140" />
        <di:waypoint x="430" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SequenceFlow_Pruefen_Gateway_di" bpmnElement="SequenceFlow_Pruefen_Gateway">
        <di:waypoint x="550" y="140" />
        <di:waypoint x="615" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SequenceFlow_AntragGenehmigt_Ja_di" bpmnElement="SequenceFlow_AntragGenehmigt_Ja">
        <di:waypoint x="665" y="140" />
        <di:waypoint x="730" y="140" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="692" y="122" width="12" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SequenceFlow_AntragGenehmigt_Nein_di" bpmnElement="SequenceFlow_AntragGenehmigt_Nein">
        <di:waypoint x="640" y="165" />
        <di:waypoint x="640" y="262" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="649" y="211" width="23" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SequenceFlow_Benachrichtigung_Ende_di" bpmnElement="SequenceFlow_Benachrichtigung_Ende">
        <di:waypoint x="870" y="140" />
        <di:waypoint x="942" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SequenceFlow_Fehler_Abgebrochen_di" bpmnElement="SequenceFlow_Fehler_Abgebrochen">
        <di:waypoint x="310" y="198" />
        <di:waypoint x="310" y="302" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
