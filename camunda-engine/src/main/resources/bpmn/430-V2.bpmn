          <dc:Bounds x="630" y="857" width="90" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Start" bpmnElement="Start_BiPRO430_001">
        <dc:Bounds x="232" y="412" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="210" y="455" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ListShipments" bpmnElement="Task_ListShipments_001">
        <dc:Bounds x="320" y="390" width="120" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_GW_Check" bpmnElement="GW_Check_001" isMarkerVisible="true">
